# Default Kamal secrets file.
#
# The main app requires explicit deployment destinations, so its deploys use:
#
#   bin/kamal deploy -d staging
#   bin/kamal deploy -d production
#
# Those read .kamal/secrets-common plus .kamal/secrets.staging/.production.
#
# This file is read by the destination-less standalone imgproxy deploy:
#
#   bin/kamal deploy -c config/deploy.imgproxy.yml
#
# Values are pulled from the environment. Do not put raw secrets here.

# imgproxy URL-signing key and salt (hex). Generate each with `openssl rand -hex 64`.
IMGPROXY_KEY=$(printenv IMGPROXY_KEY | grep . || { echo "IMGPROXY_KEY is required and must be non-empty" >&2; exit 1; })
IMGPROXY_SALT=$(printenv IMGPROXY_SALT | grep . || { echo "IMGPROXY_SALT is required and must be non-empty" >&2; exit 1; })

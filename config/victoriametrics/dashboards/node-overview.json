{
  "title": "Node overview",
  "rows": [
    {
      "title": "CPU",
      "panels": [
        {
          "title": "CPU usage %",
          "unit": "%",
          "expr": [
            "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))"
          ]
        },
        {
          "title": "Load average",
          "expr": [
            "node_load1",
            "node_load5",
            "node_load15"
          ]
        }
      ]
    },
    {
      "title": "Memory",
      "panels": [
        {
          "title": "Used memory",
          "unit": "bytes",
          "expr": [
            "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes"
          ]
        },
        {
          "title": "Memory %",
          "unit": "%",
          "expr": [
            "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100"
          ]
        }
      ]
    }
  ]
}

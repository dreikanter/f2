<% content_for :title, "Change Email Address" %>

<div class="space-y-8">
  <%= render PageHeaderComponent.new(title: "Change Email Address") %>

  <% if @user.email_deactivated? %>
    <%= render AlertComponent.new(variant: :warning, class: "max-w-2xl") do %>
      <p class="font-semibold text-heading">Your email is deactivated.</p>
      <% if @user.can_change_email? %>
        <p class="text-body">Update your email address below to continue receiving notifications.</p>
      <% else %>
        <p class="text-body">You can change your email again in <%= distance_of_time_in_words(@user.time_until_email_change_allowed) %>.</p>
      <% end %>
    <% end %>
  <% end %>

  <div class="max-w-2xl">
    <%= form_with model: @user, url: settings_email_update_path, method: :patch, local: true do |form| %>
      <div class="space-y-10">
        <div class="space-y-2">
          <%= form.label :current_email, "Current email", class: "block font-semibold text-heading" %>
          <%= form.text_field :current_email, value: @user.email_address, disabled: true, class: "w-full rounded-md border border-border-strong bg-surface px-3 py-2 text-lg leading-normal shadow-xs ring-ring transition focus:border-ring focus:outline-none focus:ring-2 disabled:bg-surface-sunken disabled:text-muted disabled:border-border disabled:cursor-not-allowed" %>
        </div>

        <div class="space-y-2">
          <%= form.label :email_address, "New email", class: "block font-semibold text-heading" %>
          <%= form.email_field :email_address, value: "", class: "w-full rounded-md border border-border-strong bg-surface px-3 py-2 text-lg leading-normal shadow-xs ring-ring transition focus:border-ring focus:outline-none focus:ring-2", placeholder: "Enter new email address", autofocus: true, autocomplete: "email" %>
        </div>
      </div>

      <div class="mt-6 flex flex-wrap items-center justify-start gap-4 text-body">
        <%= form.submit "Update Email", class: "inline-flex items-center justify-center whitespace-nowrap rounded-md bg-brand px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-brand-hover focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-1" %>
        <%= link_to "Cancel", settings_path, class: class_names("inline-flex items-center justify-center whitespace-nowrap rounded-md border border-border bg-surface px-6 py-3 text-base font-semibold text-body shadow-sm transition hover:bg-surface-muted focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-1") %>
      </div>
    <% end %>
  </div>
</div>

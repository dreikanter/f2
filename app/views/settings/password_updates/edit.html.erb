<% content_for :title, "Change Password" %>

<div class="space-y-8">
  <%= render PageHeaderComponent.new(title: "Change Password") %>

  <div class="max-w-2xl">
    <%= form_with model: @user, url: settings_password_update_path, method: :patch, local: true do |form| %>
      <div class="space-y-10">
        <div class="space-y-2">
          <%= form.label :current_password, "Current password", class: "block font-semibold text-heading" %>
          <%= form.password_field :current_password, class: "w-full rounded-md border border-border-strong bg-surface px-3 py-2 text-lg leading-normal shadow-xs ring-ring transition focus:border-ring focus:outline-none focus:ring-2", required: true, autofocus: true, autocomplete: "current-password" %>
        </div>

        <div class="space-y-2">
          <%= form.label :password, "New password", class: "block font-semibold text-heading" %>
          <%= form.password_field :password, class: "w-full rounded-md border border-border-strong bg-surface px-3 py-2 text-lg leading-normal shadow-xs ring-ring transition focus:border-ring focus:outline-none focus:ring-2", required: true, autocomplete: "new-password" %>
        </div>

        <div class="space-y-2">
          <%= form.label :password_confirmation, "Confirm new password", class: "block font-semibold text-heading" %>
          <%= form.password_field :password_confirmation, class: "w-full rounded-md border border-border-strong bg-surface px-3 py-2 text-lg leading-normal shadow-xs ring-ring transition focus:border-ring focus:outline-none focus:ring-2", required: true, autocomplete: "new-password" %>
        </div>
      </div>

      <div class="mt-6 flex flex-wrap items-center justify-start gap-4 text-body">
        <%= form.submit "Change Password", class: "inline-flex items-center justify-center whitespace-nowrap rounded-md bg-brand px-6 py-3 text-base font-semibold text-on-brand shadow-sm transition hover:bg-brand-hover focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-1" %>
        <%= link_to "Cancel", settings_path, class: class_names("inline-flex items-center justify-center whitespace-nowrap rounded-md border border-border bg-surface px-6 py-3 text-base font-semibold text-body shadow-sm transition hover:bg-surface-muted focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-1") %>
      </div>
    <% end %>
  </div>
</div>

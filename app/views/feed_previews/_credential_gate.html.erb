<%# locals: (profile_key:, missing_ai_credentials:, missing_search_credentials:) %>
<div class="rounded-lg border border-brand-subtle bg-brand-subtle p-4 space-y-3"
     data-key="credentials.gate">
  <div class="space-y-1">
    <p class="font-semibold text-brand-strong">AI extraction needs API credentials</p>
    <p class="text-brand-strong text-sm" data-key="credentials.gate.help">
      Add the missing credentials below. We'll save this feed as a draft and bring you back after each setup step.
    </p>
  </div>

  <div class="flex flex-wrap gap-3">
    <% if missing_ai_credentials %>
      <button type="submit"
              name="commit"
              value="save_as_draft_and_add_credentials"
              data-key="credentials.gate.add-ai"
              class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-brand px-4 py-2 text-sm font-semibold text-on-brand shadow-sm transition hover:bg-brand-hover">
        Add AI credentials
      </button>
    <% end %>

    <% if missing_search_credentials %>
      <button type="submit"
              name="commit"
              value="save_as_draft_and_add_search_credentials"
              data-key="credentials.gate.add-search"
              class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-brand px-4 py-2 text-sm font-semibold text-on-brand shadow-sm transition hover:bg-brand-hover">
        Add search credentials
      </button>
    <% end %>
  </div>
</div>

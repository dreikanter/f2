<%# locals: (profile_key:) %>
<div class="rounded-lg border border-brand-subtle bg-brand-subtle p-4 space-y-3"
     data-key="credentials.gate">
  <div class="space-y-1">
    <p class="font-semibold text-brand-strong">AI extraction needs your API key</p>
    <p class="text-brand-strong text-sm" data-key="credentials.gate.help">
      To let AI fetch posts on your behalf, add an API key from your AI provider. We'll come back to this feed once you're set up. We'll save your feed as a draft so you can pick up where you left off.
    </p>
  </div>

  <button type="submit"
          name="commit"
          value="save_as_draft_and_add_credentials"
          data-key="credentials.gate.add"
          class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-brand px-4 py-2 text-sm font-semibold text-on-brand shadow-sm transition hover:bg-brand-hover">
    Add AI credentials
  </button>
</div>

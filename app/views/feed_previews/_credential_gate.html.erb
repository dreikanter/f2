<%# locals: (profile_key:) %>
<div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-amber-900 space-y-2"
     data-key="preview.credential_gate">
  <p class="font-semibold">This source needs an active AI credential.</p>
  <p class="text-sm">Previews for AI-powered sources run through your AI provider, so you'll need to set one up first.</p>
  <%= link_to "Set up an AI credential", new_llm_credential_path,
              class: "inline-flex items-center gap-1 font-medium text-sky-700 underline underline-offset-4 transition hover:text-sky-600",
              data: { key: "preview.credential_gate.link" } %>
</div>

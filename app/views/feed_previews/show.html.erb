<%# locals: (preview:) %>
<%= turbo_frame_tag "feed-preview" do %>
  <%# Subscribe to the preview's stream. The preview workflow broadcasts the
      terminal (ready/failed) body to "feed-preview-body" when it finishes, so
      the result lands the instant the job completes — no client-side polling. %>
  <%= turbo_stream_from preview %>
  <div id="feed-preview-body">
    <% case preview.status %>
    <% when "ready" %>
      <%= render "feed_previews/ready", preview: preview %>
    <% when "failed" %>
      <%= render "feed_previews/failed", preview: preview %>
    <% else %>
      <%= render "feed_previews/processing", preview: preview %>
    <% end %>
  </div>
<% end %>

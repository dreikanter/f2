<% content_for :title, "Event ##{@event.id}" %>

<div class="space-y-8">
  <%= render PageHeaderComponent.new(title: "Event ##{@event.id}") do |header| %>
    <% header.with_breadcrumb(label: "Events Log", url: events_path) %>
    <% if @previous_event %>
      <% header.with_action_button do %>
        <%= link_to "← Previous", event_path(@previous_event), class: "inline-flex items-center justify-center whitespace-nowrap rounded-md border border-border bg-surface px-4 py-2 text-base font-semibold text-body shadow-sm transition hover:bg-surface-muted focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-1" %>
      <% end %>
    <% else %>
      <% header.with_action_button do %>
        <span class="inline-flex items-center justify-center whitespace-nowrap rounded-md border border-border bg-surface px-4 py-2 text-base font-semibold text-slate-300 shadow-sm cursor-not-allowed">← Previous</span>
      <% end %>
    <% end %>
    <% if @next_event %>
      <% header.with_action_button do %>
        <%= link_to "Next →", event_path(@next_event), class: "inline-flex items-center justify-center whitespace-nowrap rounded-md border border-border bg-surface px-4 py-2 text-base font-semibold text-body shadow-sm transition hover:bg-surface-muted focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-1" %>
      <% end %>
    <% else %>
      <% header.with_action_button do %>
        <span class="inline-flex items-center justify-center whitespace-nowrap rounded-md border border-border bg-surface px-4 py-2 text-base font-semibold text-slate-300 shadow-sm cursor-not-allowed">Next →</span>
      <% end %>
    <% end %>
  <% end %>

  <%= render AlertComponent.new(variant: @event.alert_variant) do %>
    <%= render EventDescriptionComponent.for(@event) %>
  <% end %>

  <%= render EventDetailsComponent.for(@event) %>

  <% if @referenced_posts.any? %>
    <section class="space-y-4" data-key="events.imported_posts">
      <h2 class="text-2xl font-semibold mb-3 text-heading">Posts</h2>
      <%= render PostsListComponent.new(posts: @referenced_posts) %>
    </section>
  <% end %>

  <% if (stats = @event.metadata&.fetch("stats", nil)).present? %>
    <section class="space-y-4" data-key="events.stats">
      <h2 class="text-2xl font-semibold mb-3 text-heading"><%= t("events.metadata.stats.section_title") %></h2>
      <%= render ListComponent.new do |list| %>
        <% stats.each do |key, value| %>
          <% list.with_item(StatListItemComponent.new(
            label: t("events.metadata.stats.#{key}", default: key.humanize),
            value: format_stat_value(key, value)
          )) %>
        <% end %>
      <% end %>
    </section>
  <% end %>
</div>

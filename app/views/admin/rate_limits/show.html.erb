<% content_for :title, "Rate Limits" %>

<%
  window_label = ->(seconds) do
    case seconds
    when 0...60 then "#{seconds}s"
    when 60...3600 then "#{seconds / 60} min"
    when 3600...86_400 then "#{seconds / 3600} h"
    else "#{seconds / 86_400} d"
    end
  end

  bar_color = ->(percent) do
    if percent >= 85 then "bg-red-500"
    elsif percent >= 60 then "bg-amber-500"
    else "bg-emerald-500"
    end
  end
%>

<div class="space-y-8">
  <%= render PageHeaderComponent.new(title: "Rate Limits") do |header| %>
    <% header.with_action_button do %>
      <%= link_to "Back to Admin", admin_path, class: class_names("inline-flex items-center justify-center whitespace-nowrap rounded-md border border-slate-200 bg-white px-4 py-2 text-base font-semibold text-slate-600 shadow-sm transition hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:ring-offset-1") %>
    <% end %>
  <% end %>

  <p class="text-slate-600">
    How much of each external API's allowance we've spent right now. Buckets refill
    continuously, so these numbers recover on their own between calls.
  </p>

  <% if @groups.empty? %>
    <%= render EmptyStateComponent.new("No rate limit activity yet. Numbers show up here once we start calling an external API.") %>
  <% else %>
    <% @groups.each do |policy, subjects| %>
      <section class="space-y-4" data-key="rate-limit.policy.<%= policy %>">
        <h2 class="text-2xl font-semibold text-slate-900"><%= policy.titleize %></h2>

        <% subjects.each do |subject, entries| %>
          <div class="space-y-3 rounded-lg border border-slate-200 bg-white p-4" data-key="rate-limit.subject" data-subject="<%= subject %>">
            <div class="flex items-center justify-between gap-2">
              <h3 class="font-mono text-sm text-slate-700"><%= subject %></h3>
              <% if entries.first&.blocked? %>
                <%= render BadgeComponent.new(text: "Cooling down · #{entries.first.blocked_for.ceil}s", color: :red, key: "rate-limit.cooldown") %>
              <% end %>
            </div>

            <% entries.each do |entry| %>
              <% percent = entry.percent_consumed %>
              <div class="flex items-center gap-3" data-key="rate-limit.bucket" data-dimension="<%= entry.dimension %>" data-window="<%= entry.window %>" data-percent="<%= percent %>">
                <div class="w-28 shrink-0 text-sm text-slate-600">
                  <span class="font-medium text-slate-800"><%= entry.dimension %></span>
                  <span class="text-slate-400">/ <%= window_label.call(entry.window) %></span>
                </div>
                <div class="h-2 flex-1 overflow-hidden rounded bg-slate-100">
                  <div class="h-full <%= bar_color.call(percent) %>" style="width: <%= percent %>%"></div>
                </div>
                <div class="w-32 shrink-0 text-right text-sm tabular-nums text-slate-600">
                  <%= entry.available.floor %> / <%= entry.burst.to_i %>
                  <span class="text-slate-400">(<%= percent %>%)</span>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </section>
    <% end %>
  <% end %>
</div>

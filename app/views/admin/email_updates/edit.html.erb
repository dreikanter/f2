<% content_for :title, "Change Email" %>

<div class="space-y-8">
  <%= render PageHeaderComponent.new(title: "Change Email for #{@user.email_address}") %>

  <%= render AlertComponent.new(variant: :info, class: "max-w-2xl") do %>
    <p><strong>How this works:</strong> You can either change the email immediately or send a confirmation email to the new address. If confirmation is required, the user must click the link in the email before the change takes effect.</p>
  <% end %>

  <div class="max-w-2xl">
    <%= form_with model: @user, url: admin_user_email_update_path(@user), method: :patch do |form| %>
      <div class="space-y-10">
        <div class="space-y-2">
          <%= form.label :current_email, "Current email", class: "block font-semibold text-heading" %>
          <%= form.text_field :current_email, value: @user.email_address, disabled: true, class: "w-full rounded-md border border-border-strong bg-surface px-3 py-2 text-lg leading-normal shadow-xs ring-ring transition focus:border-ring focus:outline-none focus:ring-2 disabled:bg-surface-sunken disabled:text-muted disabled:border-border disabled:cursor-not-allowed" %>
        </div>

        <div class="space-y-2">
          <%= form.label :email_address, "New email", class: "block font-semibold text-heading" %>
          <%= form.email_field :email_address, class: "w-full rounded-md border border-border-strong bg-surface px-3 py-2 text-lg leading-normal shadow-xs ring-ring transition focus:border-ring focus:outline-none focus:ring-2", placeholder: "Enter new email address", autofocus: true, autocomplete: "email" %>
        </div>

        <div class="space-y-2">
          <div class="flex items-start gap-3">
            <%= check_box_tag :require_confirmation, "1", false, class: "mt-1 h-4 w-4 rounded border-border-strong text-info focus:ring-ring" %>
            <%= label_tag :require_confirmation, "Require user to confirm new email address before change takes effect", class: "text-base text-heading" %>
          </div>
        </div>
      </div>

      <div class="mt-6 flex flex-wrap items-center justify-start gap-4 text-body">
        <%= form.submit "Update Email", class: "inline-flex items-center justify-center whitespace-nowrap rounded-md bg-brand px-6 py-3 text-base font-semibold text-on-brand shadow-sm transition hover:bg-brand-hover focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-1", data: { turbo_confirm: "Update email for this user?" } %>
        <%= link_to "Cancel", admin_user_path(@user), class: class_names("inline-flex items-center justify-center whitespace-nowrap rounded-md border border-border bg-surface px-6 py-3 text-base font-semibold text-body shadow-sm transition hover:bg-surface-muted focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-1") %>
      </div>
    <% end %>
  </div>
</div>

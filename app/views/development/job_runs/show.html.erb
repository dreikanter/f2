<% run_title = uuid_label(@run.id, prefix: "Run") %>
<% content_for :title, "#{@job_class.name} #{run_title.downcase}" %>

<div class="space-y-8">
  <%= render PageHeaderComponent.new(title: run_title) do |header| %>
    <% header.with_breadcrumb(label: @job_class.name, url: development_job_job_runs_path(@job_class.name)) %>
  <% end %>

  <div class="flex flex-wrap items-center gap-3" data-key="development.job_runs.<%= @run.id %>">
    <%= job_run_status_badge(@run) %>
    <span class="text-sm text-muted"><%= safe_join([
      "Enqueued #{short_time_ago(@run.created_at)}",
      (@run.started_at && @run.finished_at ? "ran for #{distance_of_time_in_words(@run.started_at, @run.finished_at, include_seconds: true)}" : nil)
    ].compact.map { |segment| tag.span(segment) }, middot) %></span>
  </div>

  <% if @events.any? %>
    <div class="space-y-4">
      <% @events.each do |event| %>
        <%= render(CardComponent.new(data: { key: "development.job_runs.#{@run.id}.event.#{event.id}" })) do |card| %>
          <% card.with_section(class: "p-4 space-y-2") do %>
            <div class="flex flex-wrap items-center gap-2">
              <%= event_level_badge(event) %>
              <span class="text-sm text-muted"><%= event.created_at.strftime("%b %d, %Y at %H:%M:%S") %></span>
            </div>
            <p class="text-base text-body"><%= event.message %></p>
          <% end %>
          <% if event.metadata.present? %>
            <% card.with_section(class: "p-4") do %>
              <pre class="overflow-x-auto font-mono text-xs text-body"><%= JSON.pretty_generate(event.metadata) %></pre>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <%= render EmptyStateComponent.new("No output recorded for this run") %>
  <% end %>
</div>

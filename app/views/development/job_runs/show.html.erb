<% content_for :title, "#{@job_class.name} run" %>

<div class="space-y-8">
  <%= render PageHeaderComponent.new(title: @job_class.name) do |header| %>
    <% header.with_breadcrumb(label: @job_class.name, url: development_job_job_runs_path(@job_class.name)) %>
  <% end %>

  <div class="flex flex-wrap items-center gap-3" data-key="development.job_runs.<%= @run.id %>">
    <%= job_run_status_badge(@run) %>
    <span class="text-sm text-muted"><%= safe_join([
      "Enqueued #{short_time_ago(@run.created_at)}",
      (@run.started_at && @run.finished_at ? "ran for #{distance_of_time_in_words(@run.started_at, @run.finished_at, include_seconds: true)}" : nil)
    ].compact.map { |segment| tag.span(segment) }, middot) %></span>
  </div>

  <% if @events.any? %>
    <%= render(ListComponent.new) do |list| %>
      <% @events.each do |event| %>
        <% item = ListItemComponent.new(data: { key: "development.job_runs.#{@run.id}.event.#{event.id}" }) %>
        <% item.with_primary do %>
          <span class="inline-flex items-center gap-2">
            <%= event_level_badge(event) %>
            <span class="text-base text-body"><%= event.message %></span>
          </span>
        <% end %>
        <% item.with_secondary do %>
          <span class="text-sm text-muted"><%= safe_join([
            tag.span(event.created_at.strftime("%b %d, %Y at %H:%M:%S")),
            (event.metadata.present? ? tag.code(event.metadata.to_json, class: "font-mono text-xs") : nil)
          ].compact, middot) %></span>
        <% end %>
        <% list.with_item(item) %>
      <% end %>
    <% end %>
  <% else %>
    <%= render EmptyStateComponent.new("No output recorded for this run") %>
  <% end %>
</div>

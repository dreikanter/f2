<% content_for :title, "Sent Emails" %>

<div class="space-y-8">
  <%= render PageHeaderComponent.new(title: "Sent Emails") do |header| %>
    <% header.with_breadcrumb(label: "Dev Tools", url: development_path) %>
    <% if @emails.any? %>
      <% header.with_action_button do %>
        <%= button_to "Purge All...",
                      purge_development_sent_emails_path,
                      method: :delete,
                      class: "inline-flex items-center justify-center whitespace-nowrap rounded-md border border-slate-200 bg-white px-4 py-2 text-base font-semibold text-slate-600 shadow-sm transition hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:ring-offset-1 cursor-pointer disabled:cursor-not-allowed disabled:opacity-50",
                      data: { turbo_confirm: "Are you sure you want to delete all emails?" } %>
      <% end %>
    <% end %>
  <% end %>

  <% if @emails.empty? %>
    <%= render AlertComponent.new(variant: :info, data: { key: "development.emails.empty" }) do %>
      No emails captured yet. Emails sent in development mode will appear here.
    <% end %>
  <% else %>
    <%= render(ListComponent.new) do |list| %>
      <% @emails.each do |email| %>
        <% item = ListComponent::ItemComponent.new(data: { key: "development.emails.list.item" }) %>
        <% item.with_primary do %>
          <%= link_to email[:subject].presence || "(no subject)", development_sent_email_path(id: email[:id]),
                class: "min-w-0 flex-1 truncate text-base text-slate-900 transition hover:text-slate-700" %>
        <% end %>
        <% item.with_secondary do %>
          <span class="text-sm text-slate-500"><%= safe_join([
            email[:timestamp].strftime("%b %d, %Y at %H:%M:%S"),
            number_to_human_size(email[:size]),
            "#{time_ago_in_words(email[:timestamp])} ago"
          ].map { |segment| tag.span(segment) }, middot) %></span>
        <% end %>
        <% list.with_item(item) %>
      <% end %>
    <% end %>
  <% end %>
</div>

<% content_for :title, "Email Previews" %>

<div class="space-y-8">
  <%= render PageHeaderComponent.new(title: "Email Previews") do |header| %>
    <% header.with_breadcrumb(label: "Dev Tools", url: development_path) %>
  <% end %>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    <% @previews.each do |preview| %>
      <%= render CardComponent.new(href: development_email_preview_path(preview[:id])) do %>
        <div class="space-y-4">
          <h2 class="flex items-center gap-2 text-lg font-semibold text-heading">
            <%= icon("mail", css_class: "size-5") %>
            <span><%= preview[:label] %></span>
          </h2>
          <p class="text-body"><%= preview[:description] %></p>
        </div>
      <% end %>
    <% end %>
  </div>
</div>

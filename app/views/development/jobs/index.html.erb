<% content_for :title, "Maintenance Jobs" %>

<div class="space-y-8">
  <%= render PageHeaderComponent.new(title: "Maintenance Jobs") do |header| %>
    <% header.with_breadcrumb(label: "Dev Tools", url: development_path) %>
    <% header.with_context_paragraph("Open a job to run it or browse its run history.") %>
  <% end %>

  <% if @jobs.any? %>
    <%= render(ListComponent.new) do |list| %>
      <% @jobs.each do |job| %>
        <% item = ListItemComponent.new(css_class: ListItemComponent::HOVER_ROW_CSS_CLASS, data: { key: "development.jobs.#{job.name}" }) %>
        <% item.with_primary do %>
          <%= link_to job.name, development_job_job_runs_path(job.name),
                class: "truncate text-base text-heading transition hover:text-heading rounded-sm outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" %>
        <% end %>
        <% list.with_item(item) %>
      <% end %>
    <% end %>
  <% else %>
    <%= render EmptyStateComponent.new("No runnable jobs registered") %>
  <% end %>
</div>

<% content_for :title, "AI Credential" %>

<%# While validation is in flight, subscribe to the credential's stream. The
    validation job broadcasts a page refresh when it resolves, so the result
    lands the instant the job finishes — no client-side polling. %>
<% if @llm_credential.pending? || @llm_credential.validating? %>
  <%= turbo_stream_from @llm_credential %>
<% end %>

<div id="llm-credential-show" class="space-y-8">
  <%= render "llm_credentials/show_content", llm_credential: @llm_credential, feed_id: @feed&.id %>
</div>

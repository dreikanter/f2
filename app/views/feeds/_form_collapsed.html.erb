<%# locals: (url: nil, prompt: nil, mode: "link", checking: false, error: nil) %>
<%# The two creation modes (spec 005 §1) as a radio pair: the radios carry the
    mechanism choice, each panel keeps its own form, and switching is pure
    disclosure — nothing is shared between the modes' fields. The action row
    sits below the whole radio group; each mode's buttons associate with their
    form through the `form` attribute and swap with the mode like the panels.

    One partial, three states (spec §7): the idle entry form; checking, which
    freezes the controls and polls for the detection outcome; and an error
    re-render with the hint under the active mode's input. A non-link error
    arrives with the AI panel pre-filled, so switching the mode radio is the
    bridge into Mode B. %>
<%
  wrapper_data = { controller: "mode-switch",
                   identification_state: checking ? "checking" : ("error" if error) }
  if checking
    wrapper_data.merge!(
      controller: "mode-switch polling",
      polling_indicate_busy_value: false,
      polling_endpoint_value: feed_identifications_path(url: url),
      polling_interval_value: polling_interval_ms,
      polling_max_polls_value: polling_max_polls,
      polling_stop_condition_value: "[data-identification-state='complete'], [data-identification-state='error']"
    )
  end
%>
<%= tag.div id: "feed-form", data: wrapper_data do %>
  <fieldset>
    <legend class="sr-only">How do you want to follow this?</legend>

    <div class="space-y-6">
      <div class="space-y-3">
        <label class="flex items-center gap-3 font-semibold text-heading" data-key="entry.mode-link">
          <%= radio_button_tag "entry_mode", "link", mode == "link",
                               disabled: checking,
                               data: { mode_switch_target: "radio", action: "change->mode-switch#switch" } %>
          Follow a feed or channel
        </label>

        <%= tag.div class: "ps-7", hidden: mode != "link",
                    data: { key: "entry.panel-link", mode: "link", mode_switch_target: "panel" } do %>
          <%= form_with url: feed_identifications_path, method: :post, id: "entry-link-form" do |f| %>
            <div class="space-y-2">
              <%# The radio label is the group's one visible label; the field
                  keeps its name for assistive tech only. %>
              <%= f.text_field :url,
                               id: "entry-link-input",
                               value: url,
                               placeholder: "https://example.com",
                               class: input_field_classes(disabled: true),
                               required: true,
                               disabled: checking,
                               autofocus: mode == "link" && !checking,
                               aria: { label: "Source link" },
                               data: { key: "form.entry-link" } %>
              <% if checking %>
                <p class="text-sm text-muted" role="status" data-key="entry.checking-status">Checking this feed — usually takes a few seconds.</p>
              <% elsif error && mode == "link" %>
                <p class="text-sm text-danger" data-key="entry.error"><%= error %></p>
              <% else %>
                <p class="text-sm text-muted">A blog, YouTube channel, subreddit, or any site with a feed.</p>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="space-y-3">
        <label class="flex items-center gap-3 font-semibold text-heading" data-key="entry.mode-ai">
          <%= radio_button_tag "entry_mode", "ai", mode == "ai",
                               disabled: checking,
                               data: { mode_switch_target: "radio", action: "change->mode-switch#switch" } %>
          Follow with AI
        </label>

        <%= tag.div class: "ps-7", hidden: mode != "ai",
                    data: { key: "entry.panel-ai", mode: "ai", mode_switch_target: "panel" } do %>
          <%= form_with url: feed_identifications_path, method: :post, id: "entry-ai-form" do |f| %>
            <div class="space-y-2">
              <%= f.text_area :prompt,
                              id: "entry-ai-input",
                              rows: 3,
                              maxlength: 2000,
                              value: prompt,
                              placeholder: "e.g. Follow A24's blog and turn each new post into a one-line announcement",
                              class: input_field_classes,
                              required: true,
                              autofocus: mode == "ai",
                              aria: { label: "What should AI follow?" },
                              data: { key: "form.entry-ai" } %>
              <% if error && mode == "ai" %>
                <p class="text-sm text-danger" data-key="entry.error"><%= error %></p>
              <% else %>
                <p class="text-sm text-muted">Describe a source or topic in your own words — a link, a few links, or what you're after. AI reads the web to keep up with it.</p>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </fieldset>

  <%= tag.div class: "mt-6 flex flex-wrap items-center justify-start gap-4 text-body", hidden: mode != "link",
              data: { key: "entry.actions-link", mode: "link", mode_switch_target: "panel" } do %>
    <% if checking %>
      <%= submit_tag "Checking…", form: "entry-link-form", disabled: true,
                     class: "#{primary_button_classes} disabled:opacity-60 disabled:cursor-not-allowed" %>
      <%= link_to "Cancel", feed_identifications_path(url: url), class: secondary_button_classes,
                  data: { turbo_method: :delete, key: "entry.cancel-check" } %>
    <% else %>
      <%= submit_tag "Continue", form: "entry-link-form", class: primary_button_classes,
                     data: { turbo_submits_with: "Checking…" } %>
      <%= link_to "Cancel", feeds_path, class: secondary_button_classes %>
    <% end %>
  <% end %>

  <%= tag.div class: "mt-6 flex flex-wrap items-center justify-start gap-4 text-body", hidden: mode != "ai",
              data: { key: "entry.actions-ai", mode: "ai", mode_switch_target: "panel" } do %>
    <%= submit_tag "Continue", form: "entry-ai-form", class: primary_button_classes,
                   data: { turbo_submits_with: "Setting up…" } %>
    <%= link_to "Cancel", feeds_path, class: secondary_button_classes %>
  <% end %>
<% end %>

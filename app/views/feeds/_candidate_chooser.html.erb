<%# locals: (candidates: [], input: nil, single: false, selected: nil) %>

<div class="space-y-2"
     data-key="candidates">
  <%= label_tag nil, "How should we fetch posts?", class: "block font-semibold text-slate-800" %>

  <div class="space-y-2">
    <% candidates.each do |attributes| %>
      <%= render CandidateOptionComponent.new(
            candidate: FeedIdentification::Candidate.new(attributes),
            input: input,
            selected: selected,
            single: single
          ) %>
    <% end %>
  </div>

  <% if single %>
    <p class="text-sm text-slate-500" data-key="candidate.single-note">This is the only way we can fetch this source, so it's locked in.</p>
  <% end %>
</div>

<%# locals: () %>
<div class="space-y-3" data-key="token.gate">
  <div class="flex gap-3">
    <div class="flex-shrink-0 pt-0.5">
      <%= icon("key-square", css_class: "size-5 text-sky-500") %>
    </div>
    <div class="space-y-1">
      <p class="font-semibold text-sky-900">A FreeFeed access token is needed</p>
      <p class="text-sky-800 text-sm">
        To post to FreeFeed on your behalf, you'll need to add a FreeFeed access token. We'll come back to this feed once you're set up.
      </p>
    </div>
  </div>

  <div class="space-y-2">
    <%# turbo_submits_with disables the button (and swaps its label) for the
        duration of the submission, so a double-click can't post twice. %>
    <button type="submit"
            name="commit"
            value="save_as_draft_and_add_token"
            data-key="token.gate.add"
            data-turbo-submits-with="Adding token…"
            class="inline-flex items-center justify-center whitespace-nowrap rounded-md bg-sky-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-sky-500 disabled:opacity-50 disabled:cursor-not-allowed">
      Add FreeFeed token
    </button>
    <p class="text-sky-800 text-sm" data-key="token.gate.help">
      We'll save your feed as a draft so you can pick up where you left off.
    </p>
  </div>
</div>

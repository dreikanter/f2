<%# locals: (f:, feed:) %>
<%
  active_credentials = Current.user.ai_credentials.active.order(:display_name)
  models_by_credential = active_credentials.to_h do |credential|
    serialized = credential.available_models.map { |model| { "id" => model["id"], "name" => (model["name"].presence || model["id"]) } }
    [credential.id.to_s, serialized.sort_by { |model| model["name"].to_s.downcase }]
  end
  ai_profile_keys = FeedProfile.all.select { |key| FeedProfile.depends_on_ai?(key) }
  section_visible = feed.feed_profile_present? && FeedProfile.depends_on_ai?(feed.feed_profile_key)
  selected_credential_id = (feed.ai_credential_id || Current.user.default_ai_credential_id || active_credentials.first&.id)&.to_s
  selected_models = models_by_credential[selected_credential_id] || []
  model_unavailable = section_visible && feed.ai_credential&.active? && feed.ai_model.present? && !feed.ai_model_available?
  select_classes = "w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-lg leading-normal shadow-xs ring-sky-500 transition focus:border-sky-500 focus:outline-none focus:ring-2"
%>
<%= tag.div(
      class: "mt-6",
      hidden: !section_visible,
      data: {
        controller: "ai-settings",
        ai_settings_models_value: models_by_credential.to_json,
        ai_settings_ai_profiles_value: ai_profile_keys.to_json,
        key: "form.ai-settings"
      }
    ) do %>
  <h2 class="text-xl font-semibold text-slate-900 mb-4">AI Settings</h2>

  <div class="space-y-6">
    <% if active_credentials.any? %>
      <% if model_unavailable %>
        <%= render PanelComponent.new(variant: :info) do %>
          <div class="space-y-1" data-key="form.ai-model-unavailable">
            <p class="font-semibold text-sky-900">Your saved model isn't available anymore</p>
            <p class="text-sky-800 text-sm">Pick a model below to keep this feed running.</p>
          </div>
        <% end %>
      <% end %>

      <%= render PanelComponent.new do %>
        <div class="space-y-2">
          <%= f.label :ai_credential_id, "AI provider", class: "block font-semibold text-slate-800" %>
          <%= f.select :ai_credential_id,
                       options_for_select(
                         active_credentials.map { |c| ["#{c.display_name} · #{LlmProvider.find(c.provider).display_name}", c.id] },
                         selected_credential_id
                       ),
                       {},
                       class: select_classes,
                       disabled: !section_visible,
                       data: { ai_settings_target: "credentialSelect", action: "change->ai-settings#refreshModels", key: "form.ai-credential" } %>
          <% if f.object.errors[:ai_credential].any? %>
            <p class="text-sm text-red-600"><%= f.object.errors[:ai_credential].first %></p>
          <% end %>
        </div>
      <% end %>

      <%= render PanelComponent.new do %>
        <div class="space-y-2">
          <%= f.label :ai_model, "Model", class: "block font-semibold text-slate-800" %>
          <%= f.select :ai_model,
                       options_for_select(selected_models.map { |model| [model["name"], model["id"]] }, feed.ai_model),
                       { include_blank: "Select a model…" },
                       class: select_classes,
                       disabled: !section_visible,
                       data: { ai_settings_target: "modelSelect", key: "form.ai-model" } %>
          <% if f.object.errors[:ai_model].any? %>
            <p class="text-sm text-red-600"><%= f.object.errors[:ai_model].first %></p>
          <% else %>
            <p class="text-sm text-slate-500">Choose the model this feed uses to fetch posts.</p>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <%= render PanelComponent.new(variant: :info) do %>
        <%= render "feed_previews/credential_gate", profile_key: feed.feed_profile_key %>
      <% end %>
    <% end %>
  </div>
<% end %>

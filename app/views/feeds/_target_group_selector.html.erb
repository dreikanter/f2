<%# locals: (feed:, groups:, token: nil, token_error: nil) %>
<div id="target-group-selector">
  <div class="space-y-2">
    <%= label_tag "feed[target_group]", "Target Group", class: "block font-semibold text-heading" %>

    <% if groups.present? %>
      <%= select_tag "feed[target_group]",
                     options_for_select(groups.sort, feed.target_group),
                     class: input_field_classes(disabled: true),
                     required: true %>
      <p class="text-sm text-muted">
        The FreeFeed group where posts will be published. Each feed can go to its own group, or you can point multiple feeds at the same one.
      </p>
      <p class="text-sm text-muted">
        Need a new group?
        <%= link_to "#{token.host}/groups/create", target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center gap-1 font-medium text-brand underline underline-offset-4 transition hover:text-brand-hover" do %>
          Create one on FreeFeed <%= icon("external-link", css_class: "size-3") %>
        <% end %>
      </p>
    <% else %>
      <%= select_tag "feed[target_group]",
                     options_for_select([[feed.target_group.presence || "Select a group", ""]]),
                     class: input_field_classes(disabled: true),
                     disabled: true %>
      <p class="text-sm text-danger">
        <% if token.nil? %>
          Unable to load groups. Please select an access token.
        <% elsif !token.active? %>
          This token is inactive. Please select a different access token or add a new one.
        <% elsif token_error == :unauthorized %>
          Unable to load groups. Please select a different access token or add a new one.
        <% elsif token_error == :empty %>
          This account doesn't manage any groups yet.
          <%= link_to "#{token.host}/groups/create", target: "_blank", rel: "noopener noreferrer",
                      class: "inline-flex items-center gap-1 font-medium text-brand underline underline-offset-4 transition hover:text-brand-hover" do %>
            Create a new group on FreeFeed <%= icon("external-link", css_class: "size-3") %>
          <% end %>
          <%= link_to "Retry", access_token_groups_path(token, feed_id: feed.id, retry: 1),
                      data: { turbo_stream: true },
                      class: "font-medium text-brand underline underline-offset-4 transition hover:text-brand-hover" %>
        <% else %>
          Could not load groups for this account.
          <%= link_to "Retry", access_token_groups_path(token, feed_id: feed.id, retry: 1),
                      data: { turbo_stream: true },
                      class: "font-medium text-brand underline underline-offset-4 transition hover:text-brand-hover" %>
        <% end %>
      </p>
    <% end %>
    <% if feed.errors[:target_group].any? %>
      <p class="text-sm text-danger"><%= feed.errors[:target_group].first %></p>
    <% end %>
  </div>
</div>

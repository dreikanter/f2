<% content_for :title, "Edit Access Token" %>

<div class="space-y-8">
  <%= render PageHeaderComponent.new(title: "Edit Access Token") %>

  <div class="max-w-2xl">
    <%= form_with model: @access_token do |form| %>
      <div class="space-y-10">
        <div class="space-y-2">
          <%= form.label :name, "Token Name", class: "block font-semibold text-heading" %>
          <%= form.text_field :name,
                              class: "w-full rounded-md border border-border-strong bg-surface px-3 py-2 text-lg leading-normal shadow-xs ring-ring transition focus:border-ring focus:outline-none focus:ring-2",
                              placeholder: "e.g., My FreeFeed Token",
                              autocomplete: "off",
                              autofocus: true %>
          <% if @access_token.errors[:name].any? %>
            <p class="text-sm text-danger"><%= @access_token.errors[:name].first %></p>
          <% end %>
        </div>

        <div class="space-y-2">
          <%= form.label :host, "FreeFeed Instance", class: "block font-semibold text-heading" %>
          <%= form.text_field :host, disabled: true, class: "w-full rounded-md border border-border-strong bg-surface px-3 py-2 text-lg leading-normal shadow-xs ring-ring transition focus:border-ring focus:outline-none focus:ring-2 disabled:bg-surface-sunken disabled:text-muted disabled:border-border disabled:cursor-not-allowed" %>
        </div>

        <div class="space-y-2">
          <%= form.label :token, "New Token Value", class: "block font-semibold text-heading" %>
          <%= form.text_field :token,
                              class: "w-full rounded-md border border-border-strong bg-surface px-3 py-2 text-lg leading-normal shadow-xs ring-ring transition focus:border-ring focus:outline-none focus:ring-2",
                              placeholder: "Paste a new token here to replace the current one",
                              autocomplete: "off" %>
          <p class="text-sm text-muted">Leave blank to keep the existing token. Entering a new value will trigger re-validation.</p>
          <% if @access_token.errors[:token].any? %>
            <p class="text-sm text-danger"><%= @access_token.errors[:token].first %></p>
          <% end %>
        </div>
      </div>

      <div class="mt-6 flex flex-wrap items-center justify-start gap-4 text-body">
        <%= form.submit "Save Changes", class: "inline-flex items-center justify-center whitespace-nowrap rounded-md bg-brand px-6 py-3 text-base font-semibold text-on-brand shadow-sm transition hover:bg-brand-hover focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-1" %>
        <%= link_to "Cancel", access_token_path(@access_token), class: "inline-flex items-center justify-center whitespace-nowrap rounded-md border border-border bg-surface px-6 py-3 text-base font-semibold text-body shadow-sm transition hover:bg-surface-muted focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-1" %>
      </div>
    <% end %>
  </div>
</div>

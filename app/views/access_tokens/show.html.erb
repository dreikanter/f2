<% content_for :title, "Access Token" %>

<%# While validation is in flight, subscribe to the token's stream. The
    validation job broadcasts a page refresh when it resolves, so the result
    lands the instant the job finishes — no client-side polling. %>
<% if @access_token.pending? || @access_token.validating? %>
  <%= turbo_stream_from @access_token %>
<% end %>

<div id="access-token-show" class="space-y-8">
  <%= render "access_tokens/show_content", access_token: @access_token, feed_id: @feed&.id %>
</div>

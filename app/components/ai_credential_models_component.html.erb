<div class="space-y-3" data-key="ai_credential.models">
  <h2 class="text-lg font-semibold text-heading">Available models</h2>
  <ul class="overflow-hidden rounded-lg border border-border bg-surface divide-y divide-border">
    <% models.each do |model| %>
      <li class="space-y-1 p-4" data-key="ai_credential.model">
        <p class="text-base font-medium text-heading" data-key="ai_credential.model.name"><%= model_name(model) %></p>
        <% if (details = model_details(model)) %>
          <p class="text-sm text-muted"><%= details %></p>
        <% end %>
      </li>
    <% end %>
  </ul>
</div>

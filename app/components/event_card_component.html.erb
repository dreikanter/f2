<li class="<%= card_classes %>" data-key="events.entry" data-event-type="<%= event.type %>" data-event-id="<%= event.id %>">
  <div class="flex items-start gap-3 px-5 py-3">
    <%= severity %>
    <div class="min-w-0 flex-1 space-y-1">
      <div class="flex items-baseline gap-3">
        <div class="min-w-0 flex-1 truncate text-slate-700" data-key="events.description">
          <%= render description %>
        </div>
        <%= timestamp_link %>
      </div>
      <% if show_footer? %>
        <div class="truncate text-sm text-slate-400" data-key="events.footer">
          <%= safe_join(footer_items, helpers.middot) %>
        </div>
      <% end %>
    </div>
  </div>
</li>

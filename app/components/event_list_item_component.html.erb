<%= render ListItemComponent.new(css_class: row_classes, data: { key: "events.entry", event_type: event.type, event_id: event.id }) do |row| %>
  <% row.with_icon do %>
    <%= severity %>
  <% end %>

  <% row.with_primary do %>
    <div class="flex min-w-0 flex-1 items-baseline gap-3">
      <div class="min-w-0 flex-1 truncate text-slate-700" data-key="events.description">
        <%= render description %>
      </div>
      <%= timestamp_link %>
    </div>
  <% end %>

  <% if show_footer? %>
    <% row.with_secondary do %>
      <div class="truncate text-sm text-slate-400" data-key="events.footer">
        <%= safe_join(footer_items, helpers.middot) %>
      </div>
    <% end %>
  <% end %>
<% end %>

<div class="w-full rounded-lg border border-slate-200 bg-white px-5 py-3 shadow-xs" data-key="events.entry" data-event-type="<%= event.type %>">
  <div class="flex items-center gap-3 text-sm">
    <%= link_to helpers.short_time_ago(event.created_at), href,
                class: "w-10 shrink-0 text-xs font-medium tabular-nums text-slate-400 hover:text-slate-700",
                title: event.created_at.rfc3339,
                data: { key: "events.timestamp" } %>
    <%= severity_dot %>
    <div class="min-w-0 flex-1 truncate text-slate-700" data-key="events.description">
      <%= render EventDescriptionComponent.for(event) %>
    </div>
    <% if (label = subject_label) %>
      <span class="shrink-0 text-xs text-slate-400"><%= label %></span>
    <% end %>
  </div>
</div>
